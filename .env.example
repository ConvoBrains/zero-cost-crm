# Copy to .env.local for local (SSH tunnel to RDS).
# Never commit real passwords.

# Local (after SSH tunnel maps RDS → localhost:5433)
# Note: one @ between password and host (not @@)
DB_URL_DEV=postgresql+asyncpg://postgres:YOUR_LOCAL_PASSWORD@localhost:5433/brains_crm_int

# API (optional)
PORT=3001
JWT_SECRET=change-me-in-production

# ─── Vercel (Project → Settings → Environment Variables) ─────────────────
# Set for Production (and Preview if needed). Either name works:
#
# DB_URL_DEV=postgresql+asyncpg://postgres:YOUR_PROD_PASSWORD@YOUR_RDS_HOST.ap-south-1.rds.amazonaws.com/brains_crm_int
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PROD_PASSWORD@YOUR_RDS_HOST/brains_crm_int
#
# JWT_SECRET=<long random string>
#
# RDS must accept connections from Vercel (public RDS + security group, or static egress IPs).

# Local secrets — copy to .env.local (gitignored). Never commit real values.

# SSH tunnel → localhost:5433
DB_URL_DEV=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5433/brains_crm_int
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5433/brains_crm_int

PORT=4000
JWT_SECRET=change-me

# S3 call recordings (server only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-recordings-bucket

# Copy to .env.local for development or .env for Docker.
# Never commit either file.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/convobrains_crm
# Optional local override (takes precedence over DATABASE_URL):
# DB_URL_DEV=postgresql://postgres:postgres@localhost:5432/convobrains_crm
DB_SSL=false

PORT=4000

# Required — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-value

# Email allow-list for login / user creation.
# Single domain (default product setting):
ALLOWED_EMAIL_DOMAIN=convobrains.com
# Multiple domains: ALLOWED_EMAIL_DOMAIN=example.com,acme.com
# Any domain (forks): ALLOWED_EMAIL_DOMAIN=*

# Comma-separated browser origins allowed for CORS.
# Leave empty in production behind the same origin (recommended).
# Local Vite + API example:
CORS_ORIGINS=http://localhost:5173,http://localhost:4000

# Optional: S3-backed call recordings (all four required when using uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
